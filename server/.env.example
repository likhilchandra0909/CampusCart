# ── CampusKart Server — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to Git.

PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campuskart

# JWT — use a long random string (e.g. openssl rand -base64 64)
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (used for CORS)
# Local dev:      http://localhost:5173
# Production:     https://your-frontend-domain.com
CLIENT_URL=http://localhost:5173

# Cloudinary — https://cloudinary.com (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
